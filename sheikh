# COMMAND: SPLIT
# --------------------------------------------------
def cmd_split(file_path: str, train_ratio: float = 0.8, stratify: bool = True):
    """
    Create train/validation split.
    
    Usage: sheikh split <file> [train_ratio] [--stratify]
    """
    logger = setup_logging("sheikh.split")
    
    path = Path(file_path)
    if not path.exists():
        logger.error(f"File not found: {path}")
        return 1
    
    logger.info(f"Creating split for: {path}")
    logger.info(f"Train ratio: {train_ratio}, Stratified: {stratify}")
    
    samples = []
    
    if path.suffix == '.jsonl':
        with open(path, 'r', encoding='utf-8') as f:
            for line in f:
                obj = json.loads(line)
                text = obj.get('text', obj.get('content', ''))
                if text:
                    obj['_text'] = text
                    samples.append(obj)
    
    elif path.suffix == '.csv':
        with open(path, 'r', encoding='utf-8', newline='') as f:
            reader = csv.DictReader(f)
            for row in reader:
                if row.get('content'):
                    row['content'] = row['content']
                    samples.append(row)
    
    if not samples:
        logger.error("No samples found")
        return 1
    
    # Stratify by length buckets
    if stratify:
        buckets = {"short": [], "medium": [], "long": []}
        for sample in samples:
            text = sample.get('_text', '')
            length = len(text)
            if length < 1500:
                buckets["short"].append(sample)
            elif length < 3000:
                buckets["medium"].append(sample)
            else:
                buckets["long"].append(sample)
        
        train, val = [], []
        for bucket in buckets.values():
            import random
            random.shuffle(bucket)
            split_idx = int(len(bucket) * train_ratio)
            train.extend(bucket[:split_idx])
            val.extend(bucket[split_idx:])
    else:
        import random
        random.shuffle(samples)
        split_idx = int(len(samples) * train_ratio)
        train, val = samples[:split_idx], samples[split_idx:]
    
    # Output files
    base_name = path.stem
    train_path = DEFAULT_DATA_DIR / f"{base_name}_train.jsonl"
    val_path = DEFAULT_DATA_DIR / f"{base_name}_val.jsonl"
    
    # Save train
    with open(train_path, 'w', encoding='utf-8') as f:
        for sample in train:
            sample_copy = {k: v for k, v in sample.items() if k != '_text'}
            f.write(json.dumps(sample_copy, ensure_ascii=False) + "\n")
    
    # Save val
    with open(val_path, 'w', encoding='utf-8') as f:
        for sample in val:
            sample_copy = {k: v for k, v in sample.items() if k != '_text'}
            f.write(json.dumps(sample_copy, ensure_ascii=False) + "\n")
    
    print("\n" + "=" * 70)
    print("DATASET SPLIT")
    print("=" * 70)
    print(f"Input:              {path}")
    print(f"Train:              {train_path} ({len(train)} samples)")
    print(f"Validation:         {val_path} ({len(val)} samples)")
    print(f"Train ratio:        {train_ratio}")
    print(f"Stratified:         {stratify}")
    print("=" * 70 + "\n")
    
    return 0


