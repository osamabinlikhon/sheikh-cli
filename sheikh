# --------------------------------------------------
def cmd_syntax(file_path: str):
    """
    Validate dataset syntax and schema.
    
    Usage: sheikh syntax <file>
    """
    logger = setup_logging("sheikh.syntax")
    
    path = Path(file_path)
    if not path.exists():
        logger.error(f"File not found: {path}")
        return 1
    
    logger.info(f"Validating: {path}")
    
    errors = []
    warnings = []
    samples_checked = 0
    
    if path.suffix == '.jsonl':
        with open(path, 'r', encoding='utf-8') as f:
            for i, line in enumerate(f, 1):
                try:
                    obj = json.loads(line)
                    samples_checked += 1
                    
                    # Check required fields
                    required_fields = ['instruction', 'output', 'id']
                    for field in required_fields:
                        if field not in obj:
                            errors.append(f"Line {i}: Missing field '{field}'")
                    
                    # Check content
                    if 'text' in obj and not obj['text'].strip():
                        warnings.append(f"Line {i}: Empty text field")
                    
                except json.JSONDecodeError as e:
                    errors.append(f"Line {i}: Invalid JSON - {e}")
    
    elif path.suffix == '.csv':
        with open(path, 'r', encoding='utf-8', newline='') as f:
            reader = csv.DictReader(f)
            for i, row in enumerate(reader, 1):
                samples_checked += 1
                if not row.get('content', '').strip():
                    warnings.append(f"Row {i}: Empty content")
    
    # Summary
    print("\n" + "=" * 70)
    print("SYNTAX VALIDATION")
    print("=" * 70)
    print(f"File:               {path}")
    print(f"Samples checked:    {samples_checked}")
    print(f"Errors:             {len(errors)}")
    print(f"Warnings:           {len(warnings)}")
    
    if errors:
        print("\nERRORS:")
        for error in errors[:10]:
            print(f"  - {error}")
        if len(errors) > 10:
            print(f"  ... and {len(errors) - 10} more")
    
    if warnings:
        print("\nWARNINGS:")
        for warning in warnings[:5]:
            print(f"  - {warning}")
        if len(warnings) > 5:
            print(f"  ... and {len(warnings) - 5} more")
    
    status = "PASSED" if not errors else "FAILED"
    print(f"\nStatus:             {status}")
    print("=" * 70 + "\n")
    
    return 0 if not errors else 1


