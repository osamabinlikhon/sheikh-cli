# COMMAND: PUSH
# --------------------------------------------------
def cmd_push(file_path: str, repo_id: Optional[str] = None, private: bool = False):
    """
    Push dataset to Hugging Face Hub.
    
    Usage: sheikh push <file> [--repo-id ID] [--private]
    """
    logger = setup_logging("sheikh.push")
    
    path = Path(file_path)
    if not path.exists():
        logger.error(f"File not found: {path}")
        return 1
    
    # Check for HF_TOKEN
    token = os.environ.get("HF_TOKEN")
    if not token:
        logger.error("HF_TOKEN not set. Run: export HF_TOKEN=your_token")
        return 1
    
    logger.info(f"Preparing to push: {path}")
    
    try:
        from datasets import load_dataset, DatasetDict
        
        # Load dataset
        base_name = path.stem
        if path.suffix == '.jsonl':
            ds = load_dataset("json", data_files=str(path))
        elif path.suffix == '.csv':
            ds = load_dataset("csv", data_files=str(path))
        else:
            logger.error("Unsupported format. Use .jsonl or .csv")
            return 1
        
        # Determine repo_id
        if not repo_id:
            repo_id = f"osamabinlikhon/{base_name}"
        
        logger.info(f"Pushing to: {repo_id}")
        
        # Push to hub
        ds.push_to_hub(repo_id, token=token, private=private)
        
        print("\n" + "=" * 70)
        print("HUGGING FACE UPLOAD")
        print("=" * 70)
        print(f"File:               {path}")
        print(f"Repo:               {repo_id}")
        print(f"Status:             SUCCESS")
        print("=" * 70 + "\n")
        
        return 0
        
    except ImportError:
        logger.error("datasets library not installed. Run: pip install datasets")
        return 1
    except Exception as e:
        logger.error(f"Upload failed: {e}")
        return 1


