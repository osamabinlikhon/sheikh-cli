# --------------------------------------------------
# HUB DISCOVERY (ASYNC)
# --------------------------------------------------
async def async_discover_urls_from_hub(
    hub_url: str,
    allow_domains: Optional[Set[str]] = None,
    session: Optional[aiohttp.ClientSession] = None
) -> List[str]:
    """
    Discover story URLs from a hub page (e.g., Google Sites, index pages).
    Extracts all outbound links and optionally filters by allowed domains.
    
    Args:
        hub_url: URL of the hub page to scrape
        allow_domains: Set of allowed domains to filter links (e.g., {"www.allbanglachoti.com"})
        session: Optional aiohttp session for connection reuse
    
    Returns:
        List of discovered URLs matching the criteria
    """
    discovered_links = set()
    should_close_session = False
    
    if session is None:
        connector = aiohttp.TCPConnector(limit=10, limit_per_host=5)
        timeout = aiohttp.ClientTimeout(total=30)
        session = aiohttp.ClientSession(
            connector=connector,
            timeout=timeout,
            headers=HEADERS
        )
        should_close_session = True
    
    try:
        logging.info(f"Fetching hub page: {hub_url}")
        
        async with session.get(hub_url) as response:
            if response.status != 200:
                logging.warning(f"Failed to fetch hub page: {hub_url} (status: {response.status})")
                return []
            
            html = await response.text()
            soup = BeautifulSoup(html, "lxml")
            
            # Extract all links from anchor tags
            for a in soup.find_all("a", href=True):
                href = a["href"].strip()
                
                # Skip empty links, anchors, and non-http(s) links
                if not href or href.startswith("#") or href.startswith("javascript:"):
                    continue
                
                # Make relative URLs absolute
                if not href.startswith("http"):
                    href = urljoin(hub_url, href)
                
                # Parse and validate URL
                try:
                    parsed = urlparse(href)
                    if not parsed.netloc:
                        continue
                except Exception:
                    continue
                
                # Filter by allowed domains if specified
                if allow_domains:
                    if parsed.netloc not in allow_domains:
                        continue
                
                discovered_links.add(href)
            
            # Remove the hub URL itself if present
            hub_parsed = urlparse(hub_url)
            discovered_links = {link for link in discovered_links 
                               if urlparse(link).netloc != hub_parsed.netloc or 
                                  urlparse(link).path != hub_parsed.path}
            
            logging.info(f"Discovered {len(discovered_links)} links from hub page")
            
    except asyncio.TimeoutError:
        logging.error(f"Timeout fetching hub page: {hub_url}")
    except aiohttp.ClientError as e:
        logging.error(f"Client error fetching hub page {hub_url}: {e}")
    except Exception as e:
        logging.error(f"Error discovering links from hub {hub_url}: {e}")
    
    finally:
        if should_close_session:
            await session.close()
    
    return sorted(discovered_links)


# --------------------------------------------------
# HUB DISCOVERY SYNC WRAPPER
# --------------------------------------------------
def discover_urls_from_hub_sync(
    hub_url: str,
    allow_domains: Optional[Set[str]] = None
) -> List[str]:
    """
    Synchronous wrapper for hub discovery (for CLI compatibility).
    """
    import requests
    
    discovered_links = set()
    
    try:
        logging.info(f"[SYNC] Fetching hub page: {hub_url}")
        
        response = requests.get(hub_url, timeout=30, headers=HEADERS)
        response.raise_for_status()
        
        soup = BeautifulSoup(response.text, "lxml")
        
        for a in soup.find_all("a", href=True):
            href = a["href"].strip()
            
            if not href or href.startswith("#") or href.startswith("javascript:"):
                continue
            
            if not href.startswith("http"):
                href = urljoin(hub_url, href)
            
            try:
                parsed = urlparse(href)
                if not parsed.netloc:
                    continue
            except Exception:
                continue
            
            if allow_domains and parsed.netloc not in allow_domains:
                continue
            
            discovered_links.add(href)
        
        logging.info(f"[SYNC] Discovered {len(discovered_links)} links from hub page")
        
    except Exception as e:
        logging.error(f"[SYNC] Error discovering links from hub {hub_url}: {e}")
    
    return sorted(discovered_links)


# --------------------------------------------------
# SITEMAP DISCOVERY (ASYNC)
# --------------------------------------------------
async def async_discover_urls_from_sitemap(
    base_url: str, 
    max_urls: int = 1000,
    session: Optional[aiohttp.ClientSession] = None
) -> List[str]:
    """
    Discover story URLs from sitemap_index.xml (handles nested sitemaps).
    Uses async HTTP for faster discovery.
    """
    all_urls = []
    should_close_session = False
    
    if session is None:
        connector = aiohttp.TCPConnector(limit=10, limit_per_host=5)
        timeout = aiohttp.ClientTimeout(total=30)
        session = aiohttp.ClientSession(
            connector=connector,
            timeout=timeout,
            headers=HEADERS
        )
        should_close_session = True
    
    try:
        sitemap_index_url = f"{base_url}/sitemap_index.xml"
        
        async with session.get(sitemap_index_url) as response:
            if response.status != 200:
                logging.warning(f"Sitemap not found at {sitemap_index_url}")
                return []
            
            text = await response.text()
            
            try:
                root = ET.fromstring(text)
            except ET.ParseError as e:
                logging.error(f"Failed to parse sitemap index: {e}")
                return []
            
            child_sitemaps = []
            for loc in root.iter():
                if loc.tag.endswith('loc'):
                    url = loc.text.strip()
                    if '/post-sitemap' in url or '/story-sitemap' in url:
                        child_sitemaps.append(url)
            
            logging.info(f"Found {len(child_sitemaps)} child sitemaps")
            
            # Fetch child sitemaps concurrently
            semaphore = asyncio.Semaphore(5)
            
            async def fetch_child_sitemap(sm_url: str) -> List[str]:
                async with semaphore:
                    try:
                        async with session.get(sm_url) as sm_response:
                            if sm_response.status == 200:
                                sm_text = await sm_response.text()
                                sm_root = ET.fromstring(sm_text)
                                urls = []
                                for loc in sm_root.iter():
                                    if loc.tag.endswith('loc'):
                                        url = loc.text.strip()
                                        # Match story URLs (numeric patterns)
                                        if re.search(r'/\d+/$', url) and '/category/' not in url and '/tag/' not in url:
                                            urls.append(url)
                                return urls
                    except Exception as e:
                        logging.warning(f"Failed to fetch {sm_url}: {e}")
                    return []
            
            # Process all child sitemaps
            tasks = [fetch_child_sitemap(url) for url in child_sitemaps]
            results = await asyncio.gather(*tasks, return_exceptions=True)
            
            for result in results:
                if isinstance(result, list):
                    all_urls.extend(result)
            
            # Limit to max_urls
            all_urls = all_urls[:max_urls]
            logging.info(f"Discovered {len(all_urls)} story URLs")
            
    finally:
        if should_close_session:
            await session.close()
    
    return all_urls


# --------------------------------------------------
# RATE LIMITER
# --------------------------------------------------
class AsyncRateLimiter:
    """Asynchronous rate limiter using token bucket algorithm."""
    
    def __init__(self, rate: float = 1.0, capacity: int = 10):
        self.rate = rate  # tokens per second
        self.capacity = capacity
        self.tokens = capacity
        self.last_update = time.monotonic()
        self._lock = asyncio.Lock()
    
    async def acquire(self):
        async with self._lock:
            now = time.monotonic()
            elapsed = now - self.last_update
            self.last_update = now
            self.tokens = min(self.capacity, self.tokens + elapsed * self.rate)
            
            if self.tokens >= 1:
                self.tokens -= 1
                return
            
            # Wait for token refill
            wait_time = (1 - self.tokens) / self.rate
            self.tokens = 0
            await asyncio.sleep(wait_time)


# --------------------------------------------------
# RETRY WITH BACKOFF
# --------------------------------------------------
async def fetch_with_retry(
    session: aiohttp.ClientSession,
    url: str,
    rate_limiter: Optional[AsyncRateLimiter] = None,
    max_retries: int = MAX_RETRIES
) -> Optional[aiohttp.ClientResponse]:
    """
    Fetch a URL with exponential backoff retry logic.
    """
    if rate_limiter:
        await rate_limiter.acquire()
    
    last_exception = None
    
    for attempt in range(max_retries):
        try:
            async with session.get(url) as response:
                if response.status == 200:
                    return response
                elif response.status == 429:  # Rate limited
                    wait_time = BACKOFF_FACTOR ** attempt * 2
                    logging.warning(f"Rate limited, waiting {wait_time}s before retry...")
                    await asyncio.sleep(wait_time)
                    last_exception = Exception(f"Rate limited (429)")
                else:
                    # Don't retry on client errors
                    return None
                    
        except asyncio.TimeoutError:
            last_exception = asyncio.TimeoutError(f"Timeout on attempt {attempt + 1}")
            wait_time = BACKOFF_FACTOR ** attempt
            await asyncio.sleep(wait_time)
        except aiohttp.ClientError as e:
            last_exception = e
            wait_time = BACKOFF_FACTOR ** attempt
            await asyncio.sleep(wait_time)
    
    if last_exception:
        logging.error(f"Failed to fetch {url} after {max_retries} attempts: {last_exception}")
    
    return None


# --------------------------------------------------
# STORY EXTRACTION
# --------------------------------------------------
def extract_story(html: str) -> Tuple[str, str]:
    """Extract title and story content from HTML."""
    soup = BeautifulSoup(html, "lxml")
    
    # Remove script and style elements
    for script in soup(["script", "style", "nav", "header", "footer"]):
        script.decompose()
    
    title_tag = soup.find("h1")
    if title_tag:
        title = title_tag.get_text(strip=True)
    else:
        title = soup.title.string if soup.title else "No Title"
        title = re.sub(r'\s*[-|]\s*(All\s*Bangla\s*Choti|গল্প|চটি).*$', '', title, flags=re.IGNORECASE)
        title = title.strip()
    
    paragraphs = soup.find_all("p")
    content_lines = []
    
    for p in paragraphs:
        text = p.get_text(strip=True)
        if not text:
            continue
        if len(text) < 30:
            continue
        if not BANGLA_RANGE.search(text):
            continue
        content_lines.append(text)
    
    content = "\n".join(content_lines)
    return title, content


# --------------------------------------------------
# CONTENT DEDUPLICATION (MINHASH SIMULATION)
# --------------------------------------------------
def compute_content_hash(content: str) -> str:
    """
    Compute a robust hash for content deduplication.
    Uses normalized content to catch near-duplicates.
    """
    # Normalize whitespace
    normalized = re.sub(r'\s+', ' ', content.strip())
    # Create hash
    return hashlib.sha256(normalized.encode('utf-8')).hexdigest()


# --------------------------------------------------
# ASYNC SCRAPING WORKER
# --------------------------------------------------
async def scrape_worker(
    worker_id: int,
    url_queue: asyncio.Queue,
    output_queue: asyncio.Queue,
    session: aiohttp.ClientSession,
    rate_limiter: AsyncRateLimiter,
    seen_hashes: Set[str],
    stats: ScrapeStats,
    logger: logging.Logger,
    pbar: tqdm
) -> None:
    """
    Worker coroutine that scrapes URLs from the queue.
    """
    while True:
        try:
            url_data = await url_queue.get()
            if url_data is None:  # Poison pill
                url_queue.put(None)
                break
            
            idx, url = url_data
            
            try:
                response = await fetch_with_retry(session, url, rate_limiter)
                
                if response is None:
                    stats.rejected["error"] += 1
                    pbar.update(1)
                    continue
                
                html = await response.text()
                title, content = extract_story(html)
                
                word_count = len(content.split()) if content else 0
                char_count = len(content)
                content_hash = compute_content_hash(content)
                
                # Validation gates
                if not content:
                    logger.debug(f"[Worker {worker_id}] Rejected (empty): {url}")
                    stats.rejected["empty"] += 1
                
                elif "<" in content or ">" in content:
                    logger.debug(f"[Worker {worker_id}] Rejected (HTML remnants): {url}")
                    stats.rejected["html"] += 1
                
                elif word_count < 50:
                    logger.debug(f"[Worker {worker_id}] Rejected (too short): {url}")
                    stats.rejected["short"] += 1
                
                elif not BANGLA_RANGE.search(content):
                    logger.debug(f"[Worker {worker_id}] Rejected (non-Bangla): {url}")
                    stats.rejected["non_bangla"] += 1
                
                elif content_hash in seen_hashes:
                    logger.debug(f"[Worker {worker_id}] Rejected (duplicate): {url}")
                    stats.duplicates += 1
                
                else:
                    seen_hashes.add(content_hash)
                    story = StoryData(
                        url=url,
                        title=title,
                        content=content,
                        word_count=word_count,
                        char_count=char_count,
                        content_hash=content_hash[:16]
                    )
                    await output_queue.put((idx, story))
                    stats.accepted += 1
                    stats.total_words += word_count
                    stats.total_chars += char_count
                    logger.info(f"[Worker {worker_id}] Accepted: {url[:60]}...")
                
            except Exception as e:
                logger.error(f"[Worker {worker_id}] Error processing {url}: {e}")
                stats.rejected["error"] += 1
            
            pbar.update(1)
            url_queue.task_done()
            
        except asyncio.CancelledError:
            break


# --------------------------------------------------
# ASYNC FILE WRITER
# --------------------------------------------------
async def file_writer(
    output_path: Path,
    output_queue: asyncio.Queue,
    total_items: int,
    logger: logging.Logger
) -> None:
    """
    Background writer that flushes data to disk.
    """
    seen_ids = set()
    
    async with aiofiles.open(output_path, 'w', newline='', encoding='utf-8') as f:
        writer = csv.writer(f)
        await writer.writerow(["id", "url", "title", "content", "word_count", "content_hash"])
        
        completed = 0
        pbar = tqdm(total=total_items, desc="Writing to disk", unit="stories")
        
        while completed < total_items:
            try:
                item = await asyncio.wait_for(output_queue.get(), timeout=5.0)
                idx, story = item
                
                # Avoid duplicate writes
                if idx not in seen_ids:
                    story_id = f"story_{idx:06d}"
                    await writer.writerow([story_id, story.url, story.title, story.content, 
                                          story.word_count, story.content_hash])
                    seen_ids.add(idx)
                    completed += 1
                
                output_queue.task_done()
                pbar.update(1)
                
            except asyncio.TimeoutError:
                continue
            except asyncio.CancelledError:
                break
        
        pbar.close()
        logger.info(f"Writer completed: {completed} stories written")


# --------------------------------------------------
# RESUME FUNCTIONALITY
# --------------------------------------------------
def get_resume_state(domain: str) -> Dict[str, Any]:
    """Load resume state from file."""
    if RESUME_FILE.exists():
        try:
            with open(RESUME_FILE, 'r', encoding='utf-8') as f:
                states = json.load(f)
                return states.get(domain, {})
        except Exception:
            pass
    return {}


def save_resume_state(domain: str, state: Dict[str, Any]) -> None:
    """Save resume state to file."""
    states = {}
    if RESUME_FILE.exists():
        try:
            with open(RESUME_FILE, 'r', encoding='utf-8') as f:
                states = json.load(f)
        except Exception:
            pass
    
    states[domain] = state
    RESUME_FILE.parent.mkdir(parents=True, exist_ok=True)
    
    with open(RESUME_FILE, 'w', encoding='utf-8') as f:
        json.dump(states, f, indent=2, ensure_ascii=False)


# --------------------------------------------------
# ROBOTS.TXT COMPLIANCE
# --------------------------------------------------
async def check_robots_txt(base_url: str, session: aiohttp.ClientSession) -> bool:
    """
    Check if the site allows crawling via robots.txt.
    Returns True if allowed, False otherwise.
    """
    parsed = urlparse(base_url)
    robots_url = f"{parsed.scheme}://{parsed.netloc}/robots.txt"
    
    try:
        async with session.get(robots_url) as response:
            if response.status != 200:
                return True  # No robots.txt, assume allowed
            
            text = await response.text()
            
            # Simple robots.txt parser
            user_agent = HEADERS["User-Agent"]
            is_allowed = True
            
            lines = text.split('\n')
            current_agent = None
            for line in lines:
                line = line.strip().lower()
                if line.startswith('user-agent:'):
                    current_agent = line.split(':')[1].strip()
                    if current_agent == '*' or current_agent in user_agent.lower():
                        is_allowed = True
                    else:
                        is_allowed = None
                elif line.startswith('disallow:') and current_agent in (user_agent.lower(), '*'):
                    path = line.split(':')[1].strip()
                    if path and base_url.endswith(path):
                        is_allowed = False
            
            return is_allowed if is_allowed is not None else True
            
    except Exception:
        return True  # If we can't check, assume allowed


# --------------------------------------------------
# COMMAND: SCRAPE (ASYNC)
# --------------------------------------------------
async def async_cmd_scrape(
    target: str,
    max_urls: int = 100,
    output_file: Optional[str] = None,
    workers: int = DEFAULT_CONCURRENT_WORKERS,
    rate: float = DEFAULT_RATE_LIMIT,
    resume: bool = False,
    check_robots: bool = True,
    mode: str = "domain",
    allow_domains: Optional[List[str]] = None
) -> int:
    """
    Scrape stories from a domain or hub page using async worker-based architecture.
    
    Args:
        target: Domain or hub URL to scrape
        max_urls: Maximum number of URLs to discover and scrape
        output_file: Optional custom output file path
        workers: Number of concurrent workers
        rate: Seconds between requests per worker (rate limiting)
        resume: Whether to resume from previous session
        check_robots: Whether to check robots.txt compliance
        mode: Discovery mode - "domain" (sitemap) or "hub" (link extraction)
        allow_domains: List of allowed domains for hub mode filtering
    
    Usage: 
        sheikh scrape <domain> [max_urls] [--output FILE] [--workers N] [--rate R]
        sheikh scrape <hub_url> [max_urls] --mode hub [--allow-domains domain1,domain2]
    """
    logger = setup_logging("sheikh.scrape")
    
    # Print colored banner
    print(ColoredOutput.highlight(f"\n{'=' * 70}"))
    print(ColoredOutput.highlight(f"Sheikh Async Scraper v{VERSION}"))
    print(ColoredOutput.highlight(f"{'=' * 70}\n"))
    
    # Determine base URL and mode
    if mode == "hub":
        base_url = target if target.startswith(('http://', 'https://')) else f"https://{target}"
        target_type = "hub"
        target_display = target
    else:
        base_url = target if target.startswith(('http://', 'https://')) else f"https://{target}"
        target_type = "domain"
        target_display = urlparse(base_url).netloc
    
    print(ColoredOutput.info(f"Target type: {target_type}"))
    print(ColoredOutput.info(f"Target: {target_display}"))
    print(ColoredOutput.info(f"Max URLs: {max_urls}"))
    print(ColoredOutput.info(f"Workers: {workers}, Rate limit: {rate}s/request\n"))
    
    if output_file:
        output_path = Path(output_file)
    else:
        safe_name = target.replace('.', '_').replace('/', '_')
        output_path = DEFAULT_OUTPUT_DIR / f"{safe_name}.csv"
    
    DEFAULT_OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    
    # Resume check
    resume_state = {}
    if resume:
        resume_state = get_resume_state(target)
        if resume_state:
            logger.info(f"Resuming from previous state: {len(resume_state.get('completed', []))} completed")
    
    # Setup async session
    connector = aiohttp.TCPConnector(limit=workers * 2, limit_per_host=workers)
    timeout = aiohttp.ClientTimeout(total=30, connect=10)
    session = aiohttp.ClientSession(
        connector=connector,
        timeout=timeout,
        headers=HEADERS
    )
    
    try:
        # Discover URLs based on mode
        print(ColoredOutput.progress(f"Discovering URLs from {target_type}..."))
        
        if mode == "hub":
            # Hub mode: extract links from hub page
            allowed_domains_set = set(allow_domains) if allow_domains else None
            urls = await async_discover_urls_from_hub(base_url, allowed_domains_set, session)
        else:
            # Domain mode: discover from sitemap
            urls = await async_discover_urls_from_sitemap(base_url, max_urls, session)
        
        if not urls:
            print(ColoredOutput.error("No URLs discovered. Exiting."))
            return 1
        
        print(ColoredOutput.success(f"Discovered {len(urls)} URLs"))
        
        # Filter already completed URLs (resume)
        completed_urls = set(resume_state.get('completed', []))
        urls_to_scrape = [url for url in urls if url not in completed_urls]
        
        if not urls_to_scrape:
            print(ColoredOutput.success("All URLs already scraped (resume complete)"))
            return 0
        
        print(ColoredOutput.info(f"URLs to scrape: {len(urls_to_scrape)} (skipped {len(completed_urls)} completed)"))
        
        # Initialize stats and shared state
        stats = ScrapeStats()
        stats.start_time = datetime.now()
        stats.urls_discovered = len(urls)
        
        seen_content_hashes = set(resume_state.get('hashes', []))
        
        # Setup queues
        url_queue: asyncio.Queue = asyncio.Queue()
        output_queue: asyncio.Queue = asyncio.Queue()
        
        # Add URLs to queue
        for idx, url in enumerate(urls_to_scrape, start=len(completed_urls) + 1):
            await url_queue.put((idx, url))
        
        # Setup rate limiter
        rate_limiter = AsyncRateLimiter(rate=rate, capacity=workers)
        
        # Create workers with colored progress
        pbar = tqdm(total=len(urls_to_scrape), desc="Scraping", unit="pages", 
                   bar_format="{l_bar}{bar}| {n_fmt}/{total_fmt} [{rate_fmt}]")
        
        worker_tasks = [
            asyncio.create_task(
                scrape_worker(
                    i + 1, url_queue, output_queue, session,
                    rate_limiter, seen_content_hashes, stats, logger, pbar
                )
            )
            for i in range(workers)
        ]
        
        # Start writer
        writer_task = asyncio.create_task(
            file_writer(output_path, output_queue, len(urls_to_scrape), logger)
        )
        
        # Wait for all scraping to complete
        await url_queue.join()
        
        # Stop workers (send poison pills)
        for _ in range(workers):
            await url_queue.put(None)
        await asyncio.gather(*worker_tasks, return_exceptions=True)
        
        # Wait for writer to finish
        await output_queue.join()
        writer_task.cancel()
        
        try:
            await writer_task
        except asyncio.CancelledError:
            pass
        
        pbar.close()
        
        stats.end_time = datetime.now()
        
        # Save resume state
        if resume:
            save_resume_state(target, {
                "completed": list(completed_urls) + [url for _, url in urls_to_scrape],
                "hashes": list(seen_content_hashes),
                "timestamp": datetime.now().isoformat()
            })
        
        # Colored summary
        print(f"\n{ColoredOutput.highlight('=' * 70)}")
        print(ColoredOutput.highlight("SCRAPING SUMMARY"))
        print(f"{ColoredOutput.highlight('=' * 70)}")
        print(f"{ColoredOutput.info(f'Duration:')}{' ' * 15}{stats.duration:.2f} seconds")
        print(f"{ColoredOutput.info(f'URLs discovered:')}{' ' * 10}{stats.urls_discovered}")
        print(f"{ColoredOutput.success(f'Stories accepted:')}{' ' * 11}{stats.accepted}")
        if stats.duplicates > 0:
            print(f"{ColoredOutput.warning(f'Duplicates removed:')}{' ' * 8}{stats.duplicates}")
        rejected_count = sum(stats.rejected.values())
        if rejected_count > 0:
            print(f"{ColoredOutput.warning(f'Rejected:')}{' ' * 18}{rejected_count}")
        if stats.accepted > 0:
            print(f"{ColoredOutput.info(f'Total words:')}{' ' * 16}{stats.total_words:,}")
            print(f"{ColoredOutput.info(f'Avg words/story:')}{' ' * 13}{stats.total_words / stats.accepted:.1f}")
            print(f"{ColoredOutput.info(f'Throughput:')}{' ' * 16}{stats.accepted / stats.duration:.1f} stories/sec")
        print(f"{ColoredOutput.info(f'Output file:')}{' ' * 16}{output_path}")
        print(f"{ColoredOutput.highlight('=' * 70)}\n")
        
        # Save stats
        stats_file = DEFAULT_OUTPUT_DIR / "scraping_stats.json"
        with open(stats_file, 'w', encoding='utf-8') as f:
            json.dump({
                "version": VERSION,
                "duration_seconds": stats.duration,
                "urls_discovered": stats.urls_discovered,
                "stories_accepted": stats.accepted,
                "duplicates_removed": stats.duplicates,
                "rejected": stats.rejected,
                "total_words": stats.total_words,
                "avg_words_per_story": stats.total_words / stats.accepted if stats.accepted > 0 else 0,
                "output_file": str(output_path),
                "mode": mode,
                "target": target
            }, f, indent=2, ensure_ascii=False)
        
        logger.info(f"Statistics saved to: {stats_file}")
        
    finally:
        await session.close()
    
    return 0


def cmd_scrape(target: str, max_urls: int = 100, output_file: Optional[str] = None,
               workers: int = DEFAULT_CONCURRENT_WORKERS, rate: float = DEFAULT_RATE_LIMIT,
               resume: bool = False, check_robots: bool = True,
               mode: str = "domain", allow_domains: Optional[List[str]] = None) -> int:
    """Synchronous wrapper for async scrape command."""
    return asyncio.run(async_cmd_scrape(
        target, max_urls, output_file, workers, rate, resume, check_robots, mode, allow_domains
    ))


