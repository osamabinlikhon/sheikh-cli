# COMMAND: STATS
# --------------------------------------------------
def cmd_stats(file_path: str):
    """
    Compute quality and length statistics.
    
    Usage: sheikh stats <file>
    """
    logger = setup_logging("sheikh.stats")
    
    path = Path(file_path)
    if not path.exists():
        logger.error(f"File not found: {path}")
        return 1
    
    logger.info(f"Computing statistics for: {path}")
    
    lengths = []
    word_counts = []
    samples = []
    
    if path.suffix == '.jsonl':
        with open(path, 'r', encoding='utf-8') as f:
            for line in f:
                obj = json.loads(line)
                text = obj.get('text', obj.get('content', ''))
                if text:
                    lengths.append(len(text))
                    word_counts.append(len(text.split()))
                    samples.append(obj)
    
    elif path.suffix == '.csv':
        with open(path, 'r', encoding='utf-8', newline='') as f:
            reader = csv.DictReader(f)
            for row in reader:
                content = row.get('content', '')
                if content:
                    lengths.append(len(content))
                    word_counts.append(len(content.split()))
                    samples.append(row)
    
    if not samples:
        logger.error("No samples found")
        return 1
    
    # Compute statistics
    report = {
        "total_samples": len(samples),
        "char_stats": {
            "min": min(lengths),
            "max": max(lengths),
            "mean": int(statistics.mean(lengths)),
            "median": int(statistics.median(lengths)),
            "stdev": int(statistics.stdev(lengths)) if len(lengths) > 1 else 0
        },
        "word_stats": {
            "min": min(word_counts),
            "max": max(word_counts),
            "mean": int(statistics.mean(word_counts)),
            "median": int(statistics.median(word_counts))
        }
    }
    
    # Output
    print("\n" + "=" * 70)
    print("QUALITY STATISTICS")
    print("=" * 70)
    print(f"File:               {path}")
    print(f"Total samples:      {report['total_samples']:,}")
    print(f"\nCharacter Length:")
    print(f"  Min:              {report['char_stats']['min']:,}")
    print(f"  Max:              {report['char_stats']['max']:,}")
    print(f"  Mean:             {report['char_stats']['mean']:,}")
    print(f"  Median:           {report['char_stats']['median']:,}")
    print(f"  Std Dev:          {report['char_stats']['stdev']:,}")
    print(f"\nWord Count:")
    print(f"  Min:              {report['word_stats']['min']:,}")
    print(f"  Max:              {report['word_stats']['max']:,}")
    print(f"  Mean:             {report['word_stats']['mean']:,}")
    print(f"  Median:           {report['word_stats']['median']:,}")
    print("=" * 70 + "\n")
    
    # Save report
    report_file = Path("reports") / "quality_report.json"
    report_file.parent.mkdir(exist_ok=True)
    with open(report_file, 'w', encoding='utf-8') as f:
        json.dump(report, f, indent=2, ensure_ascii=False)
    
    logger.info(f"Report saved to: {report_file}")
    return 0


