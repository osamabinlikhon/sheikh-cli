def main():
    parser = argparse.ArgumentParser(
        prog="sheikh",
        description=f"{Fore.CYAN}Sheikh{Style.RESET_ALL} - Bangla Dataset CLI Tool {Fore.GREEN}v{VERSION}{Style.RESET_ALL}",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"""
{Fore.YELLOW}Examples:{Style.RESET_ALL}
    {Fore.GREEN}# Domain mode (sitemap discovery){Style.RESET_ALL}
    sheikh scrape allbanglachoti.com 1000
    sheikh scrape allbanglachoti.com 1000 --workers 20 --rate 0.2
    
    {Fore.GREEN}# Hub mode (link extraction from hub page){Style.RESET_ALL}
    sheikh scrape https://sites.google.com/view/allbanglachoti/bangla-choti 500 --mode hub
    sheikh scrape https://sites.google.com/view/... 1000 --mode hub --allow-domains www.allbanglachoti.com
    
    {Fore.GREEN}# Dataset commands{Style.RESET_ALL}
    sheikh syntax data/train.jsonl
    sheikh stats data/train.jsonl
    sheikh split data/train.jsonl 0.8
    sheikh push data/train.jsonl --repo-id myname/dataset

{Fore.YELLOW}Commands:{Style.RESET_ALL}
    scrape   Scrape a domain or hub page (async, multi-worker)
    syntax   Validate dataset syntax and schema
    stats    Compute quality and length statistics
    split    Create train/validation split
    push     Push dataset to Hugging Face Hub

{Fore.YELLOW}Discovery Modes:{Style.RESET_ALL}
    --mode domain   Discover URLs from sitemap (default)
    --mode hub      Extract links from hub page (Google Sites, index pages)

{Fore.YELLOW}Async Scraping Options:{Style.RESET_ALL}
    --workers N     Number of concurrent workers (default: {DEFAULT_CONCURRENT_WORKERS})
    --rate R        Seconds between requests per worker (default: {DEFAULT_RATE_LIMIT})
    --resume        Resume interrupted scraping sessions
    --no-robots     Skip robots.txt compliance check
        """
    )
    
    parser.add_argument('--version', action='version', version=f'Sheikh v{VERSION}')
    
    subparsers = parser.add_subparsers(dest='command', help='Command to run')
    
    # Scrape command
    scrape_parser = subparsers.add_parser('scrape', help='Scrape a domain or hub page')
    scrape_parser.add_argument('target', help='Domain or hub URL to scrape (e.g., allbanglachoti.com or https://sites.google.com/...)')
    scrape_parser.add_argument('max_urls', nargs='?', type=int, default=100, 
                              help='Maximum URLs to scrape (default: 100)')
    scrape_parser.add_argument('--output', '-o', help='Output file path')
    scrape_parser.add_argument('--workers', '-w', type=int, default=DEFAULT_CONCURRENT_WORKERS,
                              help=f'Number of concurrent workers (default: {DEFAULT_CONCURRENT_WORKERS})')
    scrape_parser.add_argument('--rate', '-r', type=float, default=DEFAULT_RATE_LIMIT,
                              help=f'Requests per second per worker (default: {DEFAULT_RATE_LIMIT})')
    scrape_parser.add_argument('--resume', action='store_true',
                              help='Resume from previous session')
    scrape_parser.add_argument('--no-robots', action='store_true',
                              help='Skip robots.txt compliance check')
    scrape_parser.add_argument('--mode', '-m', choices=['domain', 'hub'], default='domain',
                              help='Discovery mode: domain (sitemap) or hub (link extraction) (default: domain)')
    scrape_parser.add_argument('--allow-domains', '-d', 
                              help='Comma-separated list of allowed domains for hub mode (e.g., www.allbanglachoti.com)')
    
    # Syntax command
    syntax_parser = subparsers.add_parser('syntax', help='Validate dataset syntax')
    syntax_parser.add_argument('file', help='Dataset file to validate')
    
    # Stats command
    stats_parser = subparsers.add_parser('stats', help='Compute quality statistics')
    stats_parser.add_argument('file', help='Dataset file to analyze')
    
    # Split command
    split_parser = subparsers.add_parser('split', help='Create train/val split')
    split_parser.add_argument('file', help='Dataset file to split')
    split_parser.add_argument('ratio', nargs='?', type=float, default=0.8,
                             help='Train ratio (default: 0.8)')
    split_parser.add_argument('--no-stratify', action='store_true',
                             help='Disable stratified splitting')
    
    # Push command
    push_parser = subparsers.add_parser('push', help='Push to Hugging Face')
    push_parser.add_argument('file', help='Dataset file to push')
    push_parser.add_argument('--repo-id', '-r', help='Repository ID (default: auto)')
    push_parser.add_argument('--private', action='store_true', help='Private repo')
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        return 1
    
    # Execute command
    if args.command == 'scrape':
        # Parse allow_domains list
        allow_domains = None
        if hasattr(args, 'allow_domains') and args.allow_domains:
            allow_domains = [d.strip() for d in args.allow_domains.split(',')]
        
        return cmd_scrape(
            args.target, 
            args.max_urls, 
            args.output,
            args.workers,
            args.rate,
            args.resume,
            not args.no_robots,
            args.mode,
            allow_domains
        )
    
    elif args.command == 'syntax':
        return cmd_syntax(args.file)
    
    elif args.command == 'stats':
        return cmd_stats(args.file)
    
    elif args.command == 'split':
        stratify = not args.no_stratify
        return cmd_split(args.file, args.ratio, stratify)
    
    elif args.command == 'push':
        return cmd_push(args.file, args.repo_id, args.private)
    
    else:
        parser.print_help()
        return 1


if __name__ == "__main__":
    sys.exit(main())
